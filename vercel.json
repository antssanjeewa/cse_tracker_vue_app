{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://www.cse.lk/api/:path*"
    },
    {
      "source": "/tv-api/:path*",
      "destination": "https://scanner.tradingview.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
